NODE_ENV=development
PORT=3000
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/DB_NAME?schema=public"

JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN=7d
JWT_SETUP_EXPIRES_IN=30m
OTP_TTL_MINUTES=15
